# countpp environment
# Copy this to .env.local for local dev, or paste values into Vercel project settings.

# iron-session cookie secret. Must be at least 32 chars.
# Generate with: openssl rand -base64 48
SESSION_PASSWORD=change-me-to-a-32-plus-char-random-string

# Exactly two whitelisted emails. Comma-separated, no spaces around commas.
ALLOWED_EMAILS=asmitdash44@gmail.com,bhanushalividhi2@gmail.com

# Vercel Blob token — auto-provisioned when the Blob store is linked to the
# Vercel project. Only needed for local dev with `vercel env pull` or similar.
BLOB_READ_WRITE_TOKEN=

# Base URL used to build magic links. Defaults to the request's own origin if unset.
APP_BASE_URL=https://countpp.vercel.app
